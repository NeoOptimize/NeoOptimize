{
  "schema_version": "1.0",
  "bundle_name": "NeoOptimize Public Runtime Bundle",
  "public_distribution": true,
  "include": [
    "assets",
    "config",
    "datasets",
    "docs",
    "lib",
    "mcp",
    "models",
    "modules",
    "skills",
    "tools"
  ],
  "exclude": [
    "lab-artifacts",
    "spice",
    "vm-tools",
    "private_keys",
    "service_role_keys",
    "tokens",
    "local_admin_credentials"
  ],
  "runtime_tools": [
    {
      "id": "nullclaw_bridge",
      "path": "tools\\nullclaw.ps1",
      "public": true,
      "mode": "safe_bridge",
      "description": "Compatibility bridge for local diagnostics. No kernel bypass or hidden driver actions are bundled."
    },
    {
      "id": "neo_mcp_bridge",
      "path": "tools\\neo_mcp_bridge.ps1",
      "public": true,
      "mode": "read_only_status",
      "description": "Reports safe connector status to NEO and RMM without exposing credentials."
    },
    {
      "id": "self_test",
      "path": "tools\\Invoke-NeoOptimizeSelfTest.ps1",
      "public": true,
      "mode": "static_validation",
      "description": "Validates required runtime files, script parsing, and UI action routing."
    }
  ],
  "safety": {
    "default_ai_mode": "advisory_only",
    "windows_doctor_default": "scan_only",
    "repair_requires_confirmation": true,
    "update_requires_sha256": true,
    "secrets_never_frontend": true
  }
}
