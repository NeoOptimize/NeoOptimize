      "rmm_command": "SYSTEM_DIAGNOSTICS",
      "risk_level": "read_only",
      "requires_admin": true,
      "supports_dry_run": true,
      "telemetry": ["host_baseline", "recent_events", "service_state", "update_state", "security_state", "performance_snapshot"],
      "preflight": ["confirm_admin_context", "collect_snapshot", "avoid_secrets"],
      "verify": ["write_doctor_report", "produce_ranked_plan", "send_ai_audit_telemetry"],
      "rollback_strategy": "none_read_only",
      "references": ["ms-get-winevent", "ms-get-command"]
