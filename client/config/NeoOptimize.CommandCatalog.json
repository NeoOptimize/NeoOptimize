  "risk_levels": {
    "read_only": "Collects state only.",
    "low": "Low-risk cleanup or cache reset with no durable system policy change.",
    "medium": "Changes user/system tuning that should be verified after execution.",
    "high": "Repairs or policy changes requiring restore point, explicit confirmation, and post-check.",
    "critical": "Remote execution or update path requiring signature, SHA-256, timeout, and audit."
