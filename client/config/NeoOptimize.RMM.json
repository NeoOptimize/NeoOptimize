{
  "schema_version": "1.0",
  "product_version": "1.0",
  "agent_version": "1.0",
  "auto_install_agent": true,
  "service_name": "NeoOptimize RMM Agent",
  "agent_install_dir": "%ProgramFiles%\\NeoOptimize\\Agent",
  "candidate_server_urls": [
    "http://127.0.0.1:3000",
    "http://192.168.122.1:3000",
    "http://10.0.2.2:3000",
    "http://host.docker.internal:3000"
  ],
  "dispatch_to_online_agents": true,
  "endpoint_sync": {
    "enabled": true,
    "checkin_interval_seconds": 30,
    "telemetry_interval_seconds": 30,
    "command_polling": true
  },
  "transport_security": {
    "prefer_https": true,
    "require_https": true,
    "allow_insecure_http_lab": false,
    "server_certificate_sha256": "",
    "sign_requests": true,
    "signature_max_skew_seconds": 300,
    "notes": "Production requires HTTPS. Isolated lab HTTP must be enabled explicitly at build/install time."
  },
  "operator_terminal": {
    "enabled": true,
    "allowed_shells": [
      "powershell",
      "cmd"
    ],
    "require_script_sha256": true,
    "max_script_chars": 20000,
    "timeout_seconds": 120
  },
  "update": {
    "use_rmm_manifest": true,
    "session_path": "/api/v1/update/session",
    "manifest_path": "/downloads/neooptimize/manifest",
    "protected_installer_path": "/downloads/neooptimize/installer",
    "installer_url": "",
    "installer_sha256": "",
    "package_sha256": "",
    "silent_args": "/S",
    "repair_args": "/S /REPAIR=1",
    "require_sha256": true,
    "auto_repair": true
  },
  "auth": {
    "token": "",
    "email": "",
    "password": ""
  },
  "enrollment_token": "",
  "telemetry": {
    "collect_device_capabilities": true,
    "collect_approx_location": false,
    "collect_verbose_diagnostics": false,
    "collect_camera_capture": false,
    "collect_microphone_capture": false,
    "collect_biometric_data": false
  }
}
