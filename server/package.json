{
  "name": "neooptimize-rmm-server",
  "version": "1.2.0",
  "description": "NeoOptimize RMM — Production API Server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "psql -U $POSTGRES_USER -d $POSTGRES_DB -f migrate_v1.sql",
    "migrate:fresh": "psql -U $POSTGRES_USER -d $POSTGRES_DB -f schema.sql",
    "keygen": "node src/security/keygen.js",
    "keygen:force": "node src/security/keygen.js --force",
    "admin:password": "node src/security/setAdminPassword.js",
    "test": "jest --runInBand --passWithNoTests",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^2.4.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "ioredis": "^5.3.2",
    "node-forge": "^1.3.1",
    "pg": "^8.11.5",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "overrides": {
    "fast-uri": "3.1.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4"
  }
}
