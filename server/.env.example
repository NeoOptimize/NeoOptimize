# ═══════════════════════════════════════════════════════════════════
# NeoOptimize RMM v1.0 — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
BUILD_DATE=2026-05-17

# ─── Database ──────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=neooptimize_rmm
POSTGRES_USER=neo_app
# GENERATE: openssl rand -hex 16
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20
POSTGRES_SSL=false

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# GENERATE: openssl rand -hex 16
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16

# ─── JWT ───────────────────────────────────────────────────────────
# GENERATE: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
JWT_EXPIRES_IN=8h

# ─── RSA Command Signing ───────────────────────────────────────────
# After running: npm run keygen
SIGNING_KEY_PASSPHRASE=CHANGE_ME_STRONG_PASSPHRASE

# ─── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# ─── Agent Settings ────────────────────────────────────────────────
AGENT_OFFLINE_THRESHOLD=2
AGENT_CHECKIN_INTERVAL=5
# If set, /api/v1/agent/register requires x-enrollment-token to match.
AGENT_ENROLLMENT_TOKEN=

# ─── WebSocket ─────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=25000

# ─── Dashboard ─────────────────────────────────────────────────────
DASHBOARD_ORIGIN=https://neooptimize.duckdns.org
VITE_API_URL=http://localhost:3000

# ─── DuckDNS ───────────────────────────────────────────────────────
# Get from: duckdns.org → Your Account → Token
DUCKDNS_TOKEN=YOUR_DUCKDNS_TOKEN
DUCKDNS_DOMAIN=neooptimize.duckdns.org

# ─── OpenFang AI ───────────────────────────────────────────────────
# GENERATE: openssl rand -hex 32
OPENFANG_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ─── Ollama Local AI (FREE — runs on your own hardware) ────────────
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull llama3
# Start: ollama serve
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Telegram Alerting ─────────────────────────────────────────────
# Create bot: @BotFather → /newbot
# Get chat_id: message @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Supabase (Audit Log Cloud Mirror) ─────────────────────────────
# Get from: supabase.com → Project Settings → API
SUPABASE_URL=
# Required for server-to-server mirror writes. Do not use anon/publishable keys here.
SUPABASE_SERVICE_ROLE_KEY=
# Legacy fallback name still supported by the server for older labs.
SUPABASE_SERVICE_KEY=

# ─── HuggingFace Spaces (Cloud AI Classifier) ──────────────────────
# Get from: huggingface.co → Settings → Access Tokens
HF_TOKEN=
HF_SPACE_ID=zenthralix/neooptimize-threat-classifier

# ─── Nullclaw Threat Intelligence ──────────────────────────────────
# Register at: nullclaw.io (leave empty to disable)
NULLCLAW_API_KEY=
NULLCLAW_URL=https://api.nullclaw.io/v1

# ─── E2B Sandboxed Execution ───────────────────────────────────────
# Get from: e2b.dev → Dashboard → API Keys
E2B_API_KEY=

# ─── Gemini AI (System Analysis) ───────────────────────────────────
# Get from: aistudio.google.com/app/apikey
GEMINI_API_KEY=
