<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
      Name="NeoOptimize"
      Manufacturer="NeoOptimize"
      Version="1.0.0"
      UpgradeCode="7E3D6D3D-6F4F-4A52-9D44-50A15AF87F8E"
      Language="1033"
      Scope="perMachine"
      InstallerVersion="500"
      Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of NeoOptimize is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="AppIcon" SourceFile="!(bindpath.resources)\neooptimize.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/NeoOptimize/NeoOptimize" />
    <Property Id="ARPHELPLINK" Value="mailto:neooptimizeofficial@gmail.com" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[#NeoOptimizeAppExe]" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Run NeoOptimize after setup" />

    <WixVariable Id="WixUILicenseRtf" Value="!(bindpath.resources)\NeoOptimize-EULA.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="!(bindpath.resources)\installer-banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="!(bindpath.resources)\installer-dialog.bmp" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="NeoOptimize">
        <Directory Id="APPINSTALLDIR" Name="App" />
        <Directory Id="SERVICEINSTALLDIR" Name="Service" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="NeoOptimize" />
    </StandardDirectory>

    <Feature Id="ProductFeature" Title="NeoOptimize" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="ServiceFiles" />
      <ComponentRef Id="NeoOptimizeAppExecutable" />
      <ComponentRef Id="NeoOptimizeServiceExecutable" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <ComponentGroup Id="AppFiles" Directory="APPINSTALLDIR">
      <Files Include="!(bindpath.app)\**">
        <Exclude Files="!(bindpath.app)\NeoOptimize.App.exe" />
      </Files>
    </ComponentGroup>

    <ComponentGroup Id="ServiceFiles" Directory="SERVICEINSTALLDIR">
      <Files Include="!(bindpath.service)\**">
        <Exclude Files="!(bindpath.service)\NeoOptimize.Service.exe" />
      </Files>
    </ComponentGroup>

    <Component Id="NeoOptimizeAppExecutable" Directory="APPINSTALLDIR" Guid="*">
      <File Id="NeoOptimizeAppExe" Source="!(bindpath.app)\NeoOptimize.App.exe" KeyPath="yes" />
    </Component>

    <Component Id="NeoOptimizeServiceExecutable" Directory="SERVICEINSTALLDIR" Guid="*">
      <File Id="NeoOptimizeServiceExe" Source="!(bindpath.service)\NeoOptimize.Service.exe" KeyPath="yes" />
      <ServiceInstall
          Id="NeoOptimizeServiceInstaller"
          Name="NeoOptimizeService"
          DisplayName="NeoOptimize Background Service"
          Description="Background telemetry, health monitoring, and AI command execution for NeoOptimize."
          Start="auto"
          Type="ownProcess"
          ErrorControl="normal"
          Account="LocalSystem" />
      <ServiceControl
          Id="NeoOptimizeServiceControl"
          Name="NeoOptimizeService"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
    </Component>

    <Component Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut
          Id="ApplicationStartMenuShortcut"
          Name="NeoOptimize"
          Description="Launch NeoOptimize"
          Target="[APPINSTALLDIR]NeoOptimize.App.exe"
          WorkingDirectory="APPINSTALLDIR" />
      <Shortcut
          Id="UninstallProduct"
          Name="Uninstall NeoOptimize"
          Target="[SystemFolder]msiexec.exe"
          Arguments="/x [ProductCode]" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\NeoOptimize" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
      <Shortcut
          Id="ApplicationDesktopShortcut"
          Name="NeoOptimize"
          Description="Launch NeoOptimize"
          Target="[APPINSTALLDIR]NeoOptimize.App.exe"
          WorkingDirectory="APPINSTALLDIR" />
      <RegistryValue Root="HKCU" Key="Software\NeoOptimize" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Package>
</Wix>




