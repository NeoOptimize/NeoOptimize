<Page
    x:Class="NeoOptimize.UI.Views.CleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="720"
    d:DesignWidth="1280">

    <Grid Padding="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Cleaner categories and controls -->
        <StackPanel Grid.Column="0" Spacing="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0,0,0,8">
                <TextBlock Text="Super Cleaner Engine" FontSize="20" FontWeight="SemiBold" Foreground="#BFE2FF" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,0,0">
                    <Button Content="Quick Scan" Width="110" Margin="8,0" Click="QuickScan_Click"/>
                    <Button Content="Clean Selected" Width="130" Margin="8,0" Click="CleanSelected_Click"/>
                </StackPanel>
            </StackPanel>

            <ItemsControl ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:CleanerCategoryViewModel">
                        <Border Background="#0F1A28" Padding="12" CornerRadius="10" Margin="0,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="{x:Bind Name}" Foreground="#B0E0FF" FontWeight="SemiBold" Width="220"/>
                                <ProgressBar Value="{x:Bind Progress}" Width="260" Height="12"/>
                                <TextBlock Text="{x:Bind Progress}" Foreground="#C0D0E5" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="#0F1A28" Padding="12" CornerRadius="12" Margin="0,8">
                <StackPanel>
                    <TextBlock Text="Scan Results (dry run)" Foreground="#B0E0FF" FontSize="16" FontWeight="SemiBold" />
                    <ListView ItemsSource="{x:Bind ViewModel.Logs}" Height="220" Margin="0,8,0,0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind .}" TextWrapping="Wrap" Foreground="#C0D0E5"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Execute (dry=false)" Click="Execute_Click" Width="160"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Right: Chat/AI and logs -->
        <StackPanel Grid.Column="1" Spacing="12">
            <Border Background="#0F1A28" Padding="12" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="NeoAI · Cleaner Assistant" Foreground="#BFE2FF" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Ask the AI to recommend cleaning policies or smart booster actions." Foreground="#C0D0E5" Margin="0,6,0,0"/>
                    <TextBox x:Name="AiInput" Height="36" Margin="0,8,0,0"/>
                    <Button Content="Ask AI" Width="90" HorizontalAlignment="Right" Click="AskAi_Click"/>
                </StackPanel>
            </Border>

            <Border Background="#0F1A28" Padding="12" CornerRadius="12">
                <TextBlock Text="Activity Log" Foreground="#BFE2FF" FontSize="16" FontWeight="SemiBold" />
                <ListView ItemsSource="{x:Bind ViewModel.Logs}" Height="320" Margin="0,8,0,0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind .}" TextWrapping="Wrap" Foreground="#B0C8E0"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </StackPanel>
    </Grid>
</Page>
