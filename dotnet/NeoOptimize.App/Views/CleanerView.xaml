<UserControl x:Class="NeoOptimize.App.Views.CleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Cleaner (Adaptive)"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Mode default membersihkan cache/temp. Aktifkan advanced untuk operasi lanjutan."
                           Margin="0,8,0,12"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <CheckBox Content="Enable Advanced Mode"
                          IsChecked="{Binding AdvancedMode}" />

                <Border Margin="0,10,0,0"
                        Background="#10253B"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <StackPanel>
                        <CheckBox Content="Registry Cleaner"
                                  IsChecked="{Binding IncludeRegistry}"
                                  IsEnabled="{Binding AdvancedMode}" />
                        <CheckBox Content="Driver Leftovers Cleaner"
                                  IsChecked="{Binding IncludeDriverLeftovers}"
                                  IsEnabled="{Binding AdvancedMode}" />
                        <CheckBox Content="Bloatware Uninstaller"
                                  IsChecked="{Binding IncludeBloatware}"
                                  IsEnabled="{Binding AdvancedMode}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10,0,0,0">
            <StackPanel>
                <TextBlock Text="Cleaning Coverage"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Safe Zone"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource AccentSoftBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Temp files, cache artifacts, session leftovers."
                           Style="{StaticResource SubtleTextStyle}" />

                <TextBlock Text="Advanced Zone"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Registry cleanup, driver residue, optional bloatware removal."
                           Style="{StaticResource SubtleTextStyle}" />

                <TextBlock Text="Safety Policy"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Gunakan Advanced hanya saat perlu. Untuk stabilitas harian, tetap di Safe Zone."
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
