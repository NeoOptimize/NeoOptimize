<UserControl x:Class="NeoOptimize.App.Views.SupportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Support"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Kontak dan kanal dukungan resmi NeoOptimize."
                           Margin="0,8,0,12"
                           Style="{StaticResource SubtleTextStyle}" />

                <TextBlock Text="{Binding DeveloperName, StringFormat='Developer: {0}'}"
                           Foreground="{StaticResource TitleBrush}" />
                <TextBlock Text="{Binding WhatsApp, StringFormat='WhatsApp: {0}'}"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource TitleBrush}" />
                <TextBlock Text="{Binding Email, StringFormat='Email: {0}'}"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource TitleBrush}" />

                <Border Margin="0,10,0,0"
                        Background="#10253B"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="{Binding BuyMeACoffee, StringFormat='BuyMeACoffee: {0}'}"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding Saweria, StringFormat='Saweria: {0}'}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding Dana, StringFormat='Dana: {0}'}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10,0,0,0">
            <StackPanel>
                <TextBlock Text="Remote Assist"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Draft ticket otomatis dibuat saat startup untuk percepat troubleshooting."
                           Margin="0,10,0,0"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding DraftTicketId, StringFormat='Draft Ticket: {0}'}"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource AccentSoftBrush}"
                           FontWeight="SemiBold" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
