<UserControl x:Class="NeoOptimize.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="$ init_dashboard.sh --verbose"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding StatusNote}"
                           Margin="0,8,0,10"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <UniformGrid Columns="2" Margin="0,0,0,10">
                    <Button Content="Clean Now"
                            Margin="0,0,8,8"
                            Command="{Binding DataContext.SmartCleanCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Button Content="Optimize Now"
                            Margin="0,0,0,8"
                            Command="{Binding DataContext.SmartOptimizeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Button Content="Smart Fix"
                            Margin="0,0,8,0"
                            Command="{Binding DataContext.SmartFixCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Button Content="Unified Scan"
                            Command="{Binding DataContext.UnifiedScanCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </UniformGrid>

                <Border BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        Background="#041A10"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="$ resource_utilization"
                                   Foreground="{StaticResource AccentSoftBrush}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding LastQuickAction, StringFormat='last_action: {0}'}"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource SubtleTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="10,0,0,0">
            <StackPanel>
                <TextBlock Text="NeoOptimize MiniTray"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" />
                <TextBlock Text="Threshold-based rules untuk auto clean dan pre-shutdown."
                           Margin="0,8,0,10"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <CheckBox Content="{Binding DataContext.MiniTrayAutoCleanIntervalMinutes, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='Auto Clean ({0} min)'}"
                          IsChecked="{Binding DataContext.MiniTrayAutoCleanEnabled, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />
                <CheckBox Content="Pre-Shutdown Cleaner"
                          IsChecked="{Binding DataContext.MiniTrayPreShutdownCleanerEnabled, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}" />

                <Border Margin="0,10,0,0"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        Padding="10"
                        Background="#072617">
                    <StackPanel>
                        <TextBlock Text="AI TIP"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding DataContext.MiniTrayAiTip, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Style="{StaticResource SubtleTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
