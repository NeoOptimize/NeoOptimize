<UserControl x:Class="NeoOptimize.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="$ init_dashboard.sh --verbose"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding StatusNote}"
                           Margin="0,8,0,10"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <UniformGrid Columns="2" Margin="0,0,0,10">
                    <Button Content="Clean Now"
                            Margin="0,0,8,8"
                            Command="{Binding DataContext.SmartCleanCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Button Content="Optimize Now"
                            Margin="0,0,0,8"
                            Command="{Binding DataContext.SmartOptimizeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Button Content="Smart Fix"
                            Margin="0,0,8,0"
                            Command="{Binding DataContext.SmartFixCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Button Content="Unified Scan"
                            Command="{Binding DataContext.UnifiedScanCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </UniformGrid>

                <Border BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        Background="#041A10"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="$ resource_utilization"
                                   Foreground="{StaticResource AccentSoftBrush}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding LastQuickAction, StringFormat='last_action: {0}'}"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource SubtleTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="10,0,0,0">
            <StackPanel>
                <TextBlock Text="NeoOptimize MiniTray"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" />
                <TextBlock Text="Threshold-based rules untuk auto clean dan pre-shutdown."
                           Margin="0,8,0,10"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />
                <CheckBox Content="Auto Clean Enabled"
                          IsChecked="{Binding MiniTrayAutoCleanEnabled, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="Interval (min):" VerticalAlignment="Center" Style="{StaticResource SubtleTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding MiniTrayAutoCleanIntervalMinutes}" VerticalAlignment="Center" Style="{StaticResource SubtleTextStyle}" />
                </StackPanel>

                <CheckBox Content="Pre-Shutdown Cleaner"
                          IsChecked="{Binding MiniTrayPreShutdownCleanerEnabled, Mode=TwoWay}" />

                <Border Margin="0,10,0,0"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        Padding="10"
                        Background="#072617">
                    <StackPanel>
                        <TextBlock Text="AI TIP"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding MiniTrayAiTip}"
                                   Style="{StaticResource SubtleTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Log Center -->
                <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Log Center" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                        <ListBox x:Name="LogsListBox" Height="200" Margin="0,8,0,0" ItemsSource="{Binding Logs}" DisplayMemberPath="DisplayName"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Export" Width="88" Margin="0,0,8,0" Command="{Binding ExportLogCommand}" CommandParameter="{Binding SelectedItem, ElementName=LogsListBox}" />
                            <Button Content="Delete" Width="88" Command="{Binding DeleteLogCommand}" CommandParameter="{Binding SelectedItem, ElementName=LogsListBox}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
