<UserControl x:Class="NeoOptimize.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Settings"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Atur mode pengalaman, tema, dan bahasa aplikasi."
                           Margin="0,8,0,12"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <TextBlock Text="Experience Mode"
                           Foreground="{StaticResource TitleBrush}" />
                <ComboBox ItemsSource="{Binding ExperienceModes}"
                          SelectedItem="{Binding ExperienceMode}" />

                <TextBlock Text="Theme"
                           Foreground="{StaticResource TitleBrush}" />
                <ComboBox ItemsSource="{Binding Themes}"
                          SelectedItem="{Binding Theme}" />

                <TextBlock Text="Language"
                           Foreground="{StaticResource TitleBrush}" />
                <ComboBox ItemsSource="{Binding Languages}"
                          SelectedItem="{Binding Language}" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10,0,0,0">
            <StackPanel>
                <TextBlock Text="Preset Recommendation"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Simple + Dark + Indonesian"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource AccentSoftBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Preset aman untuk pengguna harian dengan visibilitas yang nyaman."
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <TextBlock Text="Advanced Profile"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Gunakan saat butuh kontrol penuh modul cleaner, optimizer, dan security."
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
