<UserControl x:Class="NeoOptimize.App.Views.OptimizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Optimizer"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Smart mode membaca tekanan resource lalu memilih aksi yang paling relevan."
                           Margin="0,8,0,12"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <CheckBox Content="Privacy Pack (telemetry/background apps/tracking)"
                          IsChecked="{Binding PrivacyPackEnabled}" />

                <Border Margin="0,10,0,0"
                        Background="#10253B"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <CheckBox Content="Manual CPU tuning"
                                      IsChecked="{Binding ManualCpuTuning}" />
                            <CheckBox Content="Manual RAM tuning"
                                      IsChecked="{Binding ManualRamTuning}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <CheckBox Content="Manual Disk tuning"
                                      IsChecked="{Binding ManualDiskTuning}" />
                            <CheckBox Content="Manual Network tuning"
                                      IsChecked="{Binding ManualNetworkTuning}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10,0,0,0">
            <StackPanel>
                <TextBlock Text="Mode Strategy"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Smart Mode"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource AccentSoftBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Direkomendasikan untuk kebanyakan user: sistem memilih optimasi otomatis."
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <TextBlock Text="Manual Mode"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Aktifkan hanya modul tuning yang diperlukan untuk mencegah over-tuning."
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
