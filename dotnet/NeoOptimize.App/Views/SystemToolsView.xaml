<UserControl x:Class="NeoOptimize.App.Views.SystemToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="System Tools"
                   Foreground="{StaticResource TitleBrush}"
                   FontSize="18"
                   FontWeight="SemiBold" />
        <TextBlock Text="Smart Fix menggabungkan SFC + DISM. Backup dan restore point dipersiapkan sebelum operasi besar."
                   Margin="0,8,0,10"
                   Foreground="{StaticResource MutedBrush}"
                   TextWrapping="Wrap" />

        <CheckBox Content="Create Restore Point before repair"
                  IsChecked="{Binding CreateRestorePoint}" />
        <CheckBox Content="Backup Registry before repair"
                  IsChecked="{Binding BackupRegistry}" />
    </StackPanel>
</UserControl>
