<UserControl x:Class="NeoOptimize.App.Views.SystemToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="System Tools"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Smart Fix menjalankan rangkaian repair SFC + DISM dengan guardrail sebelum eksekusi."
                           Margin="0,8,0,12"
                           Style="{StaticResource SubtleTextStyle}"
                           TextWrapping="Wrap" />

                <CheckBox Content="Create Restore Point before repair"
                          IsChecked="{Binding CreateRestorePoint}" />
                <CheckBox Content="Backup Registry before repair"
                          IsChecked="{Binding BackupRegistry}" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10,0,0,0">
            <StackPanel>
                <TextBlock Text="Repair Guardrails"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="1. Snapshot konfigurasi penting."
                           Margin="0,10,0,0"
                           Style="{StaticResource SubtleTextStyle}" />
                <TextBlock Text="2. Jalankan sistem repair sequence."
                           Margin="0,6,0,0"
                           Style="{StaticResource SubtleTextStyle}" />
                <TextBlock Text="3. Simpan report dan status akhir."
                           Margin="0,6,0,0"
                           Style="{StaticResource SubtleTextStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
