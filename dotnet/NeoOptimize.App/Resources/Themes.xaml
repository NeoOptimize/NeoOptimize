<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#0A101A</Color>
    <Color x:Key="PanelColor">#111C2B</Color>
    <Color x:Key="PanelBorderColor">#2A3B52</Color>
    <Color x:Key="TitleColor">#F4F7FB</Color>
    <Color x:Key="MutedColor">#A9B9CA</Color>
    <Color x:Key="AccentColor">#2AD1B8</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}" />
    <SolidColorBrush x:Key="TitleBrush" Color="{StaticResource TitleColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="#21354E" />
        <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
        <Setter Property="Margin" Value="0,4,0,4" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="#1B2B40" />
        <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="Margin" Value="0,4,0,8" />
    </Style>
</ResourceDictionary>
