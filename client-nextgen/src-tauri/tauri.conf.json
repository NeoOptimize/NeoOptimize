{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeoOptimize",
  "version": "1.0.0",
  "identifier": "lab.zenthralix.neooptimize",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeoOptimize",
        "width": 1024,
        "height": 680,
        "minWidth": 1024,
        "minHeight": 680,
        "maxWidth": 1024,
        "maxHeight": 680,
        "resizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "publisher": "Zenthralix-Lab",
    "copyright": "Copyright (c) 2026 Zenthralix-Lab",
    "shortDescription": "AI-powered Windows optimization and maintenance platform.",
    "longDescription": "NeoOptimize provides AI-empowered local monitoring, NEO AI guidance, and approved Windows maintenance workflows."
  }
}
